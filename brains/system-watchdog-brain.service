[Unit]
Description=ShaneBrain Brain Farm — System Watchdog Brain
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/mnt/shanebrain-raid/shanebrain-core/mega-dashboard
ExecStart=/usr/bin/python3 brains/system-watchdog-brain.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
