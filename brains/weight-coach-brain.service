[Unit]
Description=ShaneBrain Brain Farm — Weight Coach Brain
After=network.target ollama.service

[Service]
Type=simple
User=shanebrain
WorkingDirectory=/mnt/shanebrain-raid/shanebrain-core/mega-dashboard
ExecStart=/usr/bin/python3 brains/weight-coach-brain.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
