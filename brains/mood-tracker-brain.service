[Unit]
Description=ShaneBrain Brain Farm — Mood Tracker Brain
After=network.target

[Service]
Type=simple
User=shanebrain
WorkingDirectory=/mnt/shanebrain-raid/shanebrain-core/mega-dashboard
ExecStart=/usr/bin/python3 brains/mood-tracker-brain.py
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target
