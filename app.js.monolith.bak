async function loadEmails() {
    try {
        const resp = await fetch(`${CONFIG.apiBase}/api/emails`);
        const data = await resp.json();
        const list = document.getElementById('email-list');
        const countEl = document.getElementById('email-count');
        const statusEl = document.getElementById('email-status');

        if (data.emails && data.emails.length > 0) {
            list.innerHTML = data.emails.slice(0, 8).map(em => {
                const cls = em.read ? '' : 'unread';
                const impCls = em.important ? ' important' : '';
                return `<div class="email-item ${cls}${impCls}">
                    <span class="email-time">${em.date || ''} ${em.time || ''}</span>
                    <div class="email-from">${escapeHtml(em.from || 'Unknown')}</div>
                    <div class="email-subject">${escapeHtml(em.subject || '(no subject)')}</div>
                </div>`;
            }).join('');
            countEl.textContent = `${data.unreadCount || 0} unread`;
            if (statusEl) statusEl.classList.add('online');
        } else {
            list.innerHTML = '<div class="email-placeholder">No emails to show</div>';
            countEl.textContent = '0';
        }

        // Janitor stats
        const j = data.janitor || {};
        const jCleanedEl = document.getElementById('janitor-cleaned');
        const jLastEl = document.getElementById('janitor-last');
        if (jCleanedEl) jCleanedEl.textContent = `${j.janitor_total_cleaned || 0} cleaned`;
        if (jLastEl && j.janitor_last_run) {
            const ago = Math.round((Date.now() - new Date(j.janitor_last_run)) / 60000);
            jLastEl.textContent = ago < 60 ? `${ago}m ago` : `${Math.round(ago/60)}h ago`;
        }
    } catch (e) {
        console.error('Email error:', e);
        const list = document.getElementById('email-list');
        if (list) list.innerHTML = '<div class="email-placeholder">Email service offline</div>';
    }
}

function refreshEmails() {
    document.getElementById('email-list').innerHTML =
        '<div class="email-placeholder">Refreshing...</div>';
