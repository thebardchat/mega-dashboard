        // Data to weaviate
        { source: 'weaviate', target: 'legacyknowledge', strength: 0.7 },
        { source: 'weaviate', target: 'conversations', strength: 0.7 },
        { source: 'weaviate', target: 'friendprofiles', strength: 0.6 },
